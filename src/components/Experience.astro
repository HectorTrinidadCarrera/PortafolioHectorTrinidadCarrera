---
import data from '../data/portfolio.json';
const { experience, education } = data.about;
---

<section class="section relative overflow-hidden" id="qualification">
  <!-- Background Decoration -->
  <div class="absolute top-0 left-0 w-full h-full pointer-events-none opacity-20 dark:opacity-10">
    <div class="absolute top-1/4 -left-20 w-64 h-64 bg-primary blur-[120px] rounded-full animate-pulse"></div>
    <div class="absolute bottom-1/4 -right-20 w-64 h-64 bg-secondary blur-[120px] rounded-full animate-pulse" style="animation-delay: 2s;"></div>
  </div>

  <div class="container relative z-10">
    <div class="text-center mb-12">
      <h2 class="section-title mb-2" data-aos="fade-up" data-i18n="experience_title">Trayectoria</h2>
      <span class="section-subtitle" data-aos="fade-up" data-aos-delay="100" data-i18n="experience_subtitle">Mi camino profesional y académico</span>
    </div>

    <!-- Tabs Switcher -->
    <div class="flex justify-center mb-16" data-aos="fade-up" data-aos-delay="200">
      <div class="glass-card p-1.5 flex relative w-full max-w-[400px] shadow-2xl shadow-black/10">
        <!-- Indicator Background -->
        <div id="tab-indicator" class="absolute h-[calc(100%-12px)] w-[calc(50%-6px)] bg-primary rounded-xl shadow-lg shadow-primary/30 transition-all duration-500 ease-[cubic-bezier(0.34,1.56,0.64,1)] left-1.5 top-1.5"></div>
        
        <button 
          class="qualification-button relative z-10 flex-1 py-3.5 flex items-center justify-center gap-2 text-sm font-bold transition-colors duration-300 text-white" 
          data-target="experience"
          data-i18n="experience_tab"
        >
          <iconify-icon icon="line-md:briefcase-twotone" class="text-lg"></iconify-icon> Experiencia
        </button>
        <button 
          class="qualification-button relative z-10 flex-1 py-3.5 flex items-center justify-center gap-2 text-sm font-bold transition-colors duration-300 text-text-light hover:text-white" 
          data-target="education"
          data-i18n="education_tab"
        >
          <span class="w-5 h-5 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-full h-full"><path fill="currentColor" d="M12 3L1 9l4 2.18v6L12 21l7-3.82v-6l2-1.09V17h2V9zm6.82 6L12 12.72L5.18 9L12 5.28zM17 16l-5 2.72L7 16v-3.73L12 15l5-2.73z"/></svg>
          </span> Educación
        </button>
      </div>
    </div>

    <!-- Content Area -->
    <div class="max-w-4xl mx-auto px-4 md:px-0">
      <div class="relative min-h-[500px]">
        <!-- Experience List -->
        <div id="experience-content" class="qualification-content active z-20">
          <div class="space-y-10 relative before:absolute before:inset-0 before:left-[0.625rem] md:before:left-1/2 before:-translate-x-px before:h-full before:w-0.5 before:bg-gradient-to-b before:from-primary before:via-primary/20 before:to-transparent">
            {experience.map((item, index) => (
              <div class="relative flex flex-col md:flex-row items-start md:items-center justify-between md:odd:flex-row-reverse group" data-aos="fade-up" data-aos-delay={index * 100}>
                <!-- Dot -->
                <div class="absolute left-[0.625rem] md:left-1/2 -translate-x-1/2 top-2 md:top-auto w-3.5 h-3.5 bg-primary rounded-full z-10 border-4 border-body transition-all duration-500 group-hover:scale-150 group-hover:shadow-[0_0_20px_rgba(var(--color-primary-rgb),0.6)] group-hover:border-primary/20"></div>
                
                <div class={`w-full md:w-[calc(50%-2.5rem)] pl-10 md:pl-0 ${index % 2 === 0 ? 'md:text-right' : 'md:text-left'}`}>
                  <div class="glass-card p-6 group-hover:-translate-y-1" data-tilt>
                    <div class={`flex items-center gap-4 mb-2 ${index % 2 === 0 ? 'md:flex-row-reverse' : ''}`}>
                      <div class="w-12 h-12 rounded-2xl bg-primary/10 flex items-center justify-center text-2xl text-primary group-hover:bg-primary group-hover:text-white transition-all duration-500 overflow-hidden">
                        {item.image ? (
                          <img src={item.image} alt={item.company || item.institution} class="w-full h-full object-cover" />
                        ) : item.svg ? (
                          <div class="w-8 h-8 flex items-center justify-center" set:html={item.svg} />
                        ) : (
                          <iconify-icon icon={item.icon}></iconify-icon>
                        )}
                      </div>
                      <div>
                        <h3 class="text-xl font-bold text-title group-hover:text-primary transition-colors">{item.role}</h3>
                        <span class="text-primary/90 font-semibold block text-sm tracking-wide uppercase">{item.company}</span>
                      </div>
                    </div>
                    
                    <div class={`inline-flex items-center gap-2 text-text-light text-xs font-bold bg-primary/10 border border-primary/10 px-3 py-1.5 rounded-full mb-4`}>
                      <iconify-icon icon="line-md:calendar" class="text-primary"></iconify-icon> {item.years}
                    </div>
                    <p class="text-text text-[13px] md:text-sm leading-relaxed opacity-70 group-hover:opacity-100 transition-opacity">
                      {item.description}
                    </p>
                  </div>
                </div>

                <!-- Spacer for MD to keep timeline centered -->
                <div class="hidden md:block w-[calc(50%-2.5rem)]"></div>
              </div>
            ))}
          </div>
        </div>

        <!-- Education List -->
        <div id="education-content" class="qualification-content hidden-right">
          <div class="space-y-10 relative before:absolute before:inset-0 before:left-[0.625rem] md:before:left-1/2 before:-translate-x-px before:h-full before:w-0.5 before:bg-gradient-to-b before:from-primary before:via-primary/20 before:to-transparent">
            {education.map((item, index) => (
              <div class="relative flex flex-col md:flex-row items-start md:items-center justify-between md:odd:flex-row-reverse group">
                <!-- Dot -->
                <div class="absolute left-[0.625rem] md:left-1/2 -translate-x-1/2 top-2 md:top-auto w-3.5 h-3.5 bg-primary rounded-full z-10 border-4 border-body transition-all duration-500 group-hover:scale-150 group-hover:shadow-[0_0_20px_rgba(var(--color-primary-rgb),0.6)] group-hover:border-primary/20"></div>
                
                <div class={`w-full md:w-[calc(50%-2.5rem)] pl-10 md:pl-0 ${index % 2 === 0 ? 'md:text-right' : 'md:text-left'}`}>
                  <div class="glass-card p-6 group-hover:-translate-y-1" data-tilt>
                    <div class={`flex items-center gap-4 mb-2 ${index % 2 === 0 ? 'md:flex-row-reverse' : ''}`}>
                      <div class="w-12 h-12 rounded-2xl bg-primary/10 flex items-center justify-center text-2xl text-primary group-hover:bg-primary group-hover:text-white transition-all duration-500 overflow-hidden">
                        {item.image ? (
                          <img src={item.image} alt={item.company || item.institution} class="w-full h-full object-cover" />
                        ) : item.svg ? (
                          <div class="w-8 h-8 flex items-center justify-center" set:html={item.svg} />
                        ) : (
                          <iconify-icon icon={item.icon}></iconify-icon>
                        )}
                      </div>
                      <div>
                        <h3 class="text-xl font-bold text-title group-hover:text-primary transition-colors">{item.degree}</h3>
                        <span class="text-primary/90 font-semibold block text-sm tracking-wide uppercase">{item.institution}</span>
                      </div>
                    </div>

                    <div class={`inline-flex items-center gap-2 text-text-light text-xs font-bold bg-primary/10 border border-primary/10 px-3 py-1.5 rounded-full mb-4`}>
                      <iconify-icon icon="line-md:calendar" class="text-primary"></iconify-icon> {item.years}
                    </div>
                    <p class="text-text text-[13px] md:text-sm leading-relaxed opacity-70 group-hover:opacity-100 transition-opacity">
                      {item.description}
                    </p>
                  </div>
                </div>

                <div class="hidden md:block w-[calc(50%-2.5rem)]"></div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function initQualification() {
    const buttons = document.querySelectorAll('.qualification-button');
    const indicator = document.getElementById('tab-indicator');
    const experienceContent = document.getElementById('experience-content');
    const educationContent = document.getElementById('education-content');

    if (!buttons.length || !indicator || !experienceContent || !educationContent) return;

    buttons.forEach((button, index) => {
      button.addEventListener('click', () => {
        const target = button.getAttribute('data-target');
        
        // Move indicator
        indicator.style.left = index === 0 ? '6px' : 'calc(50% + 0px)';

        // Update button styles
        buttons.forEach(btn => {
          btn.classList.remove('text-white');
          btn.classList.add('text-text-light');
        });
        button.classList.add('text-white');
        button.classList.remove('text-text-light');

        // Toggle visibility classes
        if (target === 'experience') {
          experienceContent.classList.add('active');
          experienceContent.classList.remove('hidden-left');
          
          educationContent.classList.add('hidden-right');
          educationContent.classList.remove('active');
        } else {
          educationContent.classList.add('active');
          educationContent.classList.remove('hidden-right');
          
          experienceContent.classList.add('hidden-left');
          experienceContent.classList.remove('active');
        }
      });
    });
  }

  // Initialize on load
  initQualification();

  // Re-initialize on Astro page load (for view transitions)
  document.addEventListener('astro:page-load', initQualification);
</script>

<style>
  @reference "../styles/global.css";

  .qualification-content {
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.5s ease;
    width: 100%;
  }

  .qualification-content.hidden-left {
    opacity: 0;
    transform: translateX(-30px);
    pointer-events: none;
    position: absolute;
    visibility: hidden;
  }

  .qualification-content.hidden-right {
    opacity: 0;
    transform: translateX(30px);
    pointer-events: none;
    position: absolute;
    visibility: hidden;
  }

  .qualification-content.active {
    opacity: 1;
    transform: translateX(0);
    pointer-events: auto;
    position: relative;
    visibility: visible;
  }
</style>

