---
import data from '../data/portfolio.json';
const { socials } = data;
---

<section class="section" id="contact">
  <div class="container">
    <h2 class="section-title" data-aos="fade-up" data-i18n="contact_title">Contacto</h2>
    <span class="section-subtitle" data-aos="fade-up" data-aos-delay="100" data-i18n="contact_subtitle">Ponte en contacto conmigo</span>
    
    <div class="grid md:grid-cols-2 gap-16 items-start max-w-5xl mx-auto">
      <div data-aos="fade-right">
        <h3 class="text-3xl font-bold mb-4 text-white font-display" data-i18n="contact_talk_title">¡Hablemos!</h3>
        <p class="text-base text-text mb-8 leading-relaxed" data-i18n="contact_talk_text">
          Si tienes un proyecto en mente o solo quieres saludar, no dudes en contactarme.
        </p>

        <div class="space-y-4">
          <a href={socials.linkedin} target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-primary font-bold hover:translate-x-2 transition-transform group">
            <i class="ph ph-linkedin-logo text-2xl"></i>
            <span>LinkedIn</span>
            <iconify-icon icon="line-md:arrow-right-up" class="text-xl opacity-0 group-hover:opacity-100 transition-opacity"></iconify-icon>
          </a>
          <a href={socials.github} target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-primary font-bold hover:translate-x-2 transition-transform group">
            <i class="ph ph-github-logo text-2xl"></i>
            <span>GitHub</span>
            <iconify-icon icon="line-md:arrow-right-up" class="text-xl opacity-0 group-hover:opacity-100 transition-opacity"></iconify-icon>
          </a>
          <a href={"mailto:" + socials.email} class="flex items-center gap-3 text-primary font-bold hover:translate-x-2 transition-transform group">
            <i class="ph ph-envelope-simple text-2xl"></i>
            <span>Email</span>
            <iconify-icon icon="line-md:arrow-right-up" class="text-xl opacity-0 group-hover:opacity-100 transition-opacity"></iconify-icon>
          </a>
        </div>
      </div>

      <form action="#" class="space-y-6 glass-card p-8 shadow-xl" data-tilt>
        <div class="relative">
          <label class="absolute -top-3 left-4 px-2 bg-[#080808] text-xs font-bold text-text-light transition-colors" data-i18n="contact_name_placeholder">Nombre</label>
          <input type="text" data-i18n="contact_name_placeholder" placeholder="Tu nombre" class="w-full px-4 py-4 rounded-xl border border-white/10 bg-transparent outline-none focus:border-primary transition-colors font-sans text-title text-sm">
        </div>

        <div class="relative">
          <label class="absolute -top-3 left-4 px-2 bg-[#080808] text-xs font-bold text-text-light transition-colors" data-i18n="contact_email_placeholder">Email</label>
          <input type="email" data-i18n="contact_email_placeholder" placeholder="Tu email" class="w-full px-4 py-4 rounded-xl border border-white/10 bg-transparent outline-none focus:border-primary transition-colors font-sans text-title text-sm">
        </div>

        <div class="relative">
          <label class="absolute -top-3 left-4 px-2 bg-[#080808] text-xs font-bold text-text-light transition-colors" data-i18n="contact_message_placeholder">Mensaje</label>
          <textarea data-i18n="contact_message_placeholder" placeholder="Tu mensaje" class="w-full px-4 py-4 rounded-xl border border-white/10 bg-transparent outline-none focus:border-primary transition-colors font-sans h-32 resize-none text-title text-sm"></textarea>
        </div>

        <button type="submit" class="w-full btn py-4" data-i18n="contact_send">Enviar Mensaje</button>
      </form>
    </div>
  </div>
</section>
