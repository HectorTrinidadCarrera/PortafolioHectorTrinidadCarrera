---
import data from '../data/portfolio.json';
const { description, experience } = data.about;
---

<section class="section" id="about">
  <h2 class="section-title" data-aos="fade-up" data-i18n="about_title">Sobre Mí</h2>
  <span class="section-subtitle" data-aos="fade-up" data-aos-delay="100" data-i18n="about_subtitle">Mi presentación</span>

  <div class="container grid md:grid-cols-2 gap-10 items-center">
    <!-- Left Column: Glowing circular card image -->
    <div class="flex justify-center" data-aos="fade-right">
      <div class="relative w-64 h-64 md:w-80 md:h-80 flex items-center justify-center">
        <div class="photo-container w-full h-full relative">
          <!-- Profile Image -->
          <div class="relative z-10 w-full h-full flex items-center justify-center animate-float">
            <img 
              src="/images/HectorTC.png" 
              alt={data.profile.name} 
              loading="lazy"
              decoding="async"
              class="w-full h-full object-contain scale-[1.3] md:scale-[1.5]"
            />
          </div>
          <div class="photo-glow absolute inset-0 rounded-full scale-105 bg-[radial-gradient(circle,_var(--color-primary)_0%,_transparent_70%)] opacity-30 animate-pulse z-0"></div>
        </div>
      </div>
    </div>

    <!-- Right Column: Info details -->
    <div class="space-y-8" data-aos="fade-left">
      <p class="text-text leading-relaxed text-sm md:text-base" data-i18n="about_description">
        {description}
      </p>

      <div class="grid grid-cols-3 gap-4">
        <!-- Experience Card -->
        <div class="glass-card p-4 text-center flex flex-col items-center justify-center" data-tilt>
          <iconify-icon icon="line-md:calendar" class="text-2xl text-primary block mb-1"></iconify-icon>
          <h3 class="text-xs font-bold text-white transition-colors" data-i18n="about_card_exp_title">Experiencia</h3>
          <span class="text-[10px] text-text-light font-semibold mt-1" data-i18n="about_card_exp_subtitle">2+ Años</span>
        </div>
        
        <!-- Completed Projects Card -->
        <div class="glass-card p-4 text-center flex flex-col items-center justify-center" data-tilt>
          <iconify-icon icon="line-md:clipboard-check-twotone" class="text-2xl text-primary block mb-1"></iconify-icon>
          <h3 class="text-xs font-bold text-white transition-colors" data-i18n="about_card_proj_title">Completado</h3>
          <span class="text-[10px] text-text-light font-semibold mt-1" data-i18n="about_card_proj_subtitle">15+ Proyectos</span>
        </div>
        
        <!-- Support Card -->
        <div class="glass-card p-4 text-center flex flex-col items-center justify-center" data-tilt>
          <iconify-icon icon="line-md:phone-call-loop" class="text-2xl text-primary block mb-1"></iconify-icon>
          <h3 class="text-xs font-bold text-white transition-colors" data-i18n="about_card_support_title">Soporte</h3>
          <span class="text-[10px] text-text-light font-semibold mt-1" data-i18n="about_card_support_subtitle">24/7 Online</span>
        </div>
      </div>

      <!-- Contact Info with Icons -->
      <div class="flex flex-col gap-4 py-6 border-y border-[var(--color-border)]">
        {data.profile.info.map(item => (
          <div class="flex items-center gap-4 group">
            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-white transition-all duration-300">
              <iconify-icon icon={item.icon} class="text-xl"></iconify-icon>
            </div>
            <div>
              <p class="text-xs text-text-light font-bold uppercase tracking-wider">{item.label}</p>
              <p class="text-title font-medium text-sm">{item.value}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="pt-4 flex justify-center md:justify-start">
        <a href="#contact" class="btn" data-i18n="about_more_btn">
          Saber más <i class="ph ph-arrow-right"></i>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  @reference "../styles/global.css";

  .profile-mask {
    mask-image: linear-gradient(to bottom, 
      rgba(0,0,0,1) 0%, 
      rgba(0,0,0,1) 80%, 
      rgba(0,0,0,0) 100%
    );
    -webkit-mask-image: linear-gradient(to bottom, 
      rgba(0,0,0,1) 0%, 
      rgba(0,0,0,1) 80%, 
      rgba(0,0,0,0) 100%
    );
  }

  .profile-mask::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 60px;
    background: linear-gradient(to top, var(--color-body), transparent);
    z-index: 20;
    pointer-events: none;
  }
</style>

<script>
  // Ensure Lottie animation in About section only plays once when scrolled into view
  function initAboutLottie() {
    const lottiePlayer = document.getElementById('about-lottie');
    if (!lottiePlayer) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          // Play the animation
          (lottiePlayer as any).play();
          // Stop observing so it only plays once
          observer.unobserve(lottiePlayer);
        }
      });
    }, { threshold: 0.5 });

    observer.observe(lottiePlayer);
  }

  // Run on initial load
  initAboutLottie();

  // Run on view transitions
  document.addEventListener('astro:page-load', initAboutLottie);
</script>
