---
import data from '../data/portfolio.json';
const { name } = data.profile;
---

<footer class="bg-gray-900 text-white py-16">
  <div class="max-w-7xl mx-auto px-4 text-center">
    <h1 class="text-3xl font-bold mb-8">{name}<span class="text-primary">.</span></h1>
    
    <ul class="flex justify-center gap-8 mb-8 text-gray-400 font-semibold">
      <li><a href="#about" class="hover:text-white transition-colors">About</a></li>
      <li><a href="#projects" class="hover:text-white transition-colors">Projects</a></li>
      <li><a href="#skills" class="hover:text-white transition-colors">Skills</a></li>
    </ul>

    <div class="flex justify-center gap-6 mb-12">
      <a href={data.socials.linkedin} target="_blank" class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-gray-400 hover:bg-primary hover:text-white transition-all duration-300">
        <iconify-icon icon="line-md:linkedin" class="text-xl"></iconify-icon>
      </a>
      <a href={data.socials.github} target="_blank" class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-gray-400 hover:bg-primary hover:text-white transition-all duration-300">
        <iconify-icon icon="line-md:github-loop" class="text-xl"></iconify-icon>
      </a>
      <a href={data.socials.twitter} target="_blank" class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-gray-400 hover:bg-primary hover:text-white transition-all duration-300">
        <iconify-icon icon="line-md:twitter-x" class="text-xl"></iconify-icon>
      </a>
    </div>

    <p class="text-sm text-gray-500">
      &#169; {new Date().getFullYear()} {name}. Todos los derechos reservados.
    </p>
  </div>
</footer>
