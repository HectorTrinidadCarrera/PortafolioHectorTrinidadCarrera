---
interface Props {
  title: string;
  description: string;
  image: string;
  technologies: string[];
  icon: string;
  links: {
    demo: string;
    github: string;
  };
  index: number;
}

const { title, description, image, technologies, icon, links, index } = Astro.props;

const techIconMap: Record<string, string> = {
  "React": "logos:react",
  "Node.js": "logos:nodejs-icon",
  "MongoDB": "logos:mongodb-icon",
  "Astro": "logos:astro-icon",
  "Tailwind": "logos:tailwindcss-icon",
  "JavaScript": "logos:javascript",
  "Vue": "logos:vue",
  "D3.js": "logos:d3",
  "Firebase": "logos:firebase",
  "Python": "logos:python",
  "HTML": "logos:html-5",
  "CSS": "logos:css-3",
  "Express": "logos:express",
  "SQL": "logos:mysql",
  "MySQL": "logos:mysql",
  "PostgreSQL": "logos:postgresql",
  "Next.js": "logos:nextjs-icon",
  "Java": "logos:java",
  "Maven": "logos:maven",
  "Vercel": "logos:vercel-icon",
  "Vite": "logos:vitejs",
  "Spring Boot": "logos:spring-boot",
  "Html": "logos:html-5",
  "TypeScript": "logos:typescript-icon",
  "Docker": "logos:docker-icon",
  "GitHub": "logos:github-icon",
  "Figma": "logos:figma",
};

const resolvePath = (path: string) => {
  if (!path) return '';
  if (path.startsWith('http://') || path.startsWith('https://') || path.startsWith('#')) return path;
  if (path.startsWith('/')) {
    return import.meta.env.BASE_URL + path.slice(1);
  }
  return import.meta.env.BASE_URL + path;
};
---

<div 
  class="project-card group bg-container rounded-[2.5rem] overflow-hidden shadow-sm hover:shadow-2xl premium-transition transform border border-[var(--color-border)] opacity-0 translate-y-10 flex flex-col h-full"
>
  <!-- Card Header / Image Area -->
  <div class="relative h-64 bg-gradient-to-br from-primary/5 to-primary/20 overflow-hidden flex items-center justify-center">
    <!-- Project Image -->
    {image && (
      <img 
        src={resolvePath(image)} 
        alt={title}
        loading="lazy"
        decoding="async"
        class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-1000"
      />
    )}
    
    <!-- Animated Overlay if no image or as accent -->
    <div class="absolute inset-0 opacity-20 group-hover:scale-125 transition-transform duration-1000 bg-black/10">
      <div class="absolute top-0 left-0 w-full h-full bg-[radial-gradient(circle_at_center,_var(--color-primary)_0%,_transparent_70%)]"></div>
    </div>
    
    <!-- Main Project Icon Overlay -->
    <div class="relative z-10 w-24 h-24 bg-container/90 backdrop-blur-md rounded-3xl shadow-xl flex items-center justify-center text-5xl transform group-hover:-rotate-3 group-hover:scale-105 premium-transition">
      <iconify-icon icon={icon}></iconify-icon>
    </div>

    <!-- Floating Decoration -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <iconify-icon icon="line-md:code-loop" class="absolute -top-4 -left-4 text-7xl opacity-5"></iconify-icon>
      <iconify-icon icon="line-md:loading-twotone-loop" class="absolute -bottom-4 -right-4 text-7xl opacity-5"></iconify-icon>
    </div>

    <!-- Floating Tag -->
    <div class="absolute top-6 right-6 px-4 py-1.5 bg-primary/90 backdrop-blur-md text-white rounded-full text-[10px] font-black uppercase tracking-widest shadow-lg">
      Latest Project
    </div>
  </div>

  <div class="p-8 flex flex-col flex-1">
    <div class="flex items-center gap-2 mb-4">
       <div class="w-1.5 h-6 bg-primary rounded-full"></div>
       <h3 class="text-2xl font-black text-title group-hover:text-primary transition-colors duration-300">{title}</h3>
    </div>
    
    <div class="flex-1">
      <p class="text-text-light mb-6 line-clamp-3 leading-relaxed text-sm">{description}</p>
      
      <!-- Tech Stack with Icons -->
      <div class="flex flex-wrap gap-2 mb-8">
        {technologies.map(tech => (
          <span class="flex items-center gap-1.5 px-3 py-1 bg-body-variant/50 border border-[var(--color-border)] text-text-light text-[10px] uppercase tracking-tighter font-black rounded-lg group-hover:border-primary/30 transition-colors duration-300">
            <iconify-icon icon={techIconMap[tech] || "line-md:hash-small"} class="text-xs"></iconify-icon>
            {tech}
          </span>
        ))}
      </div>
    </div>

    <div class="flex items-center justify-between pt-4 border-t border-[var(--color-border)]/50">
      <div class="flex items-center gap-6">
        <a href={resolvePath(links.demo)} class="flex items-center gap-2 font-black text-xs text-primary hover:gap-4 transition-all tracking-widest">
          EXPLORAR <iconify-icon icon="line-md:arrow-right" class="text-lg"></iconify-icon>
        </a>
      </div>
      
      <div class="flex items-center gap-3">
        <a href={links.github} class="w-10 h-10 flex items-center justify-center rounded-xl bg-body-variant/50 text-xl text-text-light hover:text-primary hover:bg-primary/10 transition-all border border-[var(--color-border)]/50">
          <iconify-icon icon="line-md:github-loop"></iconify-icon>
        </a>
      </div>
    </div>
  </div>
</div>
