---
interface Props {
  title: string;
  description: string;
  image: string;
  technologies: string[];
  icon: string;
  links: {
    demo: string;
    github: string;
  };
  index: number;
}

const { title, description, image, technologies, icon, links, index } = Astro.props;

const techIconMap: Record<string, string> = {
  "React": "logos:react",
  "Node.js": "logos:nodejs-icon",
  "MongoDB": "logos:mongodb-icon",
  "Astro": "logos:astro-icon",
  "Tailwind": "logos:tailwindcss-icon",
  "JavaScript": "logos:javascript",
  "Vue": "logos:vue",
  "D3.js": "logos:d3",
  "Firebase": "logos:firebase",
  "Python": "logos:python",
  "HTML": "logos:html-5",
  "CSS": "logos:css-3",
  "Express": "logos:express",
  "SQL": "logos:mysql",
  "MySQL": "logos:mysql",
  "PostgreSQL": "logos:postgresql",
  "Next.js": "logos:nextjs-icon",
  "Java": "logos:java",
  "Maven": "logos:maven",
  "Vercel": "logos:vercel-icon",
  "Vite": "logos:vitejs",
  "Spring Boot": "logos:spring-boot",
  "Html": "logos:html-5",
  "TypeScript": "logos:typescript-icon",
  "Docker": "logos:docker-icon",
  "GitHub": "logos:github-icon",
  "Figma": "logos:figma",
};
---

<div 
  class="project-card group glass-card rounded-[2rem] overflow-hidden shadow-sm hover:shadow-2xl premium-transition transform opacity-0 translate-y-10 flex flex-col h-full"
  data-tilt
>
  <!-- Card Header / Image Area -->
  <div class="relative h-56 bg-gradient-to-br from-primary/5 to-primary/20 overflow-hidden flex items-center justify-center">
    <!-- Project Image -->
    {image && (
      <img 
        src={image} 
        alt={title}
        loading="lazy"
        decoding="async"
        class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
      />
    )}
    
    <!-- Animated Overlay if no image or as accent -->
    <div class="absolute inset-0 opacity-10 group-hover:scale-125 transition-transform duration-700 bg-black/10">
      <div class="absolute top-0 left-0 w-full h-full bg-[radial-gradient(circle_at_center,_var(--color-primary)_0%,_transparent_70%)]"></div>
    </div>
    
    <!-- Main Project Icon Overlay -->
    <div class="relative z-10 w-20 h-20 bg-[#121212]/90 backdrop-blur-md rounded-2xl border border-white/5 flex items-center justify-center text-4xl transform group-hover:-rotate-3 group-hover:scale-105 premium-transition">
      <iconify-icon icon={icon}></iconify-icon>
    </div>

    <!-- Floating Decoration -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <iconify-icon icon="line-md:code-loop" class="absolute -top-4 -left-4 text-7xl opacity-5"></iconify-icon>
      <iconify-icon icon="line-md:loading-twotone-loop" class="absolute -bottom-4 -right-4 text-7xl opacity-5"></iconify-icon>
    </div>

    <!-- Floating Tag -->
    <div class="absolute top-4 right-4 px-3 py-1 bg-primary/95 backdrop-blur-md text-white rounded-full text-[9px] font-black uppercase tracking-widest shadow-lg" data-i18n="projects_latest">
      Latest Project
    </div>
  </div>

  <div class="p-6 flex flex-col flex-1">
    <div class="flex items-center gap-2 mb-3">
       <div class="w-1 h-5 bg-primary rounded-full"></div>
       <h3 class="text-xl font-bold text-white group-hover:text-primary transition-colors duration-300">{title}</h3>
    </div>
    
    <div class="flex-1">
      <p class="text-text mb-5 line-clamp-3 leading-relaxed text-xs">{description}</p>
      
      <!-- Tech Stack with Icons -->
      <div class="flex flex-wrap gap-1.5 mb-6">
        {technologies.map(tech => (
          <span class="flex items-center gap-1 px-2.5 py-1 bg-white/5 border border-white/5 text-text-light text-[9px] uppercase font-bold rounded-lg group-hover:border-primary/20 transition-colors duration-300">
            <iconify-icon icon={techIconMap[tech] || "line-md:hash-small"} class="text-xs"></iconify-icon>
            {tech}
          </span>
        ))}
      </div>
    </div>

    <div class="flex items-center justify-between pt-4 border-t border-white/5">
      <div class="flex items-center gap-6">
        <a href={links.demo} class="flex items-center gap-2 font-bold text-xs text-primary hover:gap-4 transition-all tracking-wider" data-i18n="projects_explore">
          EXPLORAR <iconify-icon icon="line-md:arrow-right" class="text-lg"></iconify-icon>
        </a>
      </div>
      
      {links.github && (
        <div class="flex items-center gap-3">
          <a href={links.github} target="_blank" rel="noopener noreferrer" class="w-9 h-9 flex items-center justify-center rounded-xl bg-white/5 text-lg text-text hover:text-primary hover:bg-primary/10 transition-all border border-white/5">
            <i class="ph ph-github-logo"></i>
          </a>
        </div>
      )}
    </div>
  </div>
</div>
