---
// Redesigned Navbar matching virues134-source reference
---

<header class="fixed top-0 left-0 w-full z-50 transition-all duration-300" id="header">
  <nav class="max-w-5xl mx-auto px-6 h-16 flex justify-between items-center relative">
    <!-- Brand Logo -->
    <a href="#home" class="nav-logo relative z-50 font-display text-xl font-bold flex items-center tracking-tight text-white select-none">
      <span class="logo-bracket text-primary font-bold mr-1">&lt;</span>HT<span class="logo-bracket text-primary font-bold ml-1">/&gt;</span>
    </a>

    <!-- Menu Links -->
    <div class="flex items-center gap-6">
      <ul class="nav-links flex gap-8" id="nav-links">
        <li><a href="#about" class="nav-link font-medium text-text hover:text-primary transition-colors text-sm" data-i18n="nav_about">Sobre mí</a></li>
        <li><a href="#skills" class="nav-link font-medium text-text hover:text-primary transition-colors text-sm" data-i18n="nav_skills">Habilidades</a></li>
        <li><a href="#qualification" class="nav-link font-medium text-text hover:text-primary transition-colors text-sm" data-i18n="nav_resume">Trayectoria</a></li>
        <li><a href="#projects" class="nav-link font-medium text-text hover:text-primary transition-colors text-sm" data-i18n="nav_projects">Proyectos</a></li>
        <li><a href="#certifications" class="nav-link font-medium text-text hover:text-primary transition-colors text-sm" data-i18n="nav_certifications">Certificaciones</a></li>
        <li><a href="#contact" class="nav-link font-medium text-text hover:text-primary transition-colors text-sm" data-i18n="nav_contact">Contacto</a></li>
      </ul>
      
      <!-- Right Side Actions: Lang Toggle & Hamburger -->
      <div class="flex items-center gap-4 relative z-50">
        <!-- Language Switcher -->
        <button id="lang-toggle" class="lang-toggle flex items-center justify-center font-bold px-3 py-1.5 rounded-xl border border-white/10 bg-white/5 hover:border-primary/40 hover:bg-primary/5 transition-all text-xs cursor-pointer select-none text-white" aria-label="Cambiar idioma">
          <span class="lang-label" id="lang-label">EN</span>
        </button>

        <!-- Hamburger (Mobile) -->
        <button id="hamburger" class="hamburger flex flex-col justify-between w-6 h-5 cursor-pointer md:hidden relative z-50" aria-label="Menú" aria-expanded="false">
          <span class="hamburger-line w-full h-[2px] bg-white rounded-md transition-all duration-300 origin-left"></span>
          <span class="hamburger-line w-full h-[2px] bg-white rounded-md transition-all duration-300"></span>
          <span class="hamburger-line w-full h-[2px] bg-white rounded-md transition-all duration-300 origin-left"></span>
        </button>
      </div>
    </div>
  </nav>
</header>

<!-- Backdrop Overlay for Mobile Menu -->
<div id="menu-backdrop" class="menu-backdrop"></div>

<style>
  @reference "../styles/global.css";

  /* Force GPU acceleration on the fixed header to respect z-index hierarchy in WebKit (Safari/Brave iOS) */
  header {
    transform: translate3d(0, 0, 0);
    -webkit-transform: translate3d(0, 0, 0);
  }

  /* Header scroll effect matching reference site */
  header.scrolled {
    padding: 4px 0;
    background: rgba(8, 8, 8, 0.75);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--color-border);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.4);
  }

  /* Navigation Links styling */
  .nav-link {
    position: relative;
    padding: 4px 0;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--color-primary);
    transition: width 0.3s ease;
  }

  .nav-link:hover::after,
  .nav-link.active-link::after {
    width: 100%;
  }

  .nav-link.active-link {
    color: var(--color-primary) !important;
  }

  /* Language toggle glow styling */
  .lang-toggle:hover {
    box-shadow: 0 0 15px rgba(163, 117, 255, 0.15);
  }

  /* Hamburger lines animation when active */
  #hamburger.active .hamburger-line:nth-child(1) {
    transform: rotate(45deg) translate(2px, -2px);
  }
  #hamburger.active .hamburger-line:nth-child(2) {
    opacity: 0;
    transform: scale(0);
  }
  #hamburger.active .hamburger-line:nth-child(3) {
    transform: rotate(-45deg) translate(2px, 2px);
  }

  /* Menu Backdrop Overlay with forced GPU acceleration */
  .menu-backdrop {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 35;
    transform: translate3d(0, 0, 0);
    -webkit-transform: translate3d(0, 0, 0);
  }

  .menu-backdrop.active {
    opacity: 1;
    pointer-events: auto;
  }

  /* Mobile menu rules with forced GPU acceleration */
  @media (max-width: 768px) {
    .nav-links {
      position: fixed;
      top: 0;
      right: -100%;
      width: 75%;
      max-width: 300px;
      height: 100vh;
      background: rgba(8, 8, 8, 0.85);
      backdrop-filter: blur(25px);
      -webkit-backdrop-filter: blur(25px);
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 2.25rem;
      border-left: 1px solid rgba(255, 255, 255, 0.08);
      box-shadow: -10px 0 30px rgba(0, 0, 0, 0.5);
      transition: right 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      z-index: 40;
      padding: 2rem;
      transform: translate3d(0, 0, 0);
      -webkit-transform: translate3d(0, 0, 0);
    }

    .nav-links.active {
      right: 0;
    }

    .nav-links a {
      font-size: 1.15rem;
      font-family: 'Space Grotesk', sans-serif;
      letter-spacing: 0.05em;
      transition: all 0.3s ease;
      display: inline-block;
    }
    
    .nav-links a:hover {
      transform: translateX(4px);
    }
  }

  :global(body.menu-open) {
    overflow: hidden;
    touch-action: none;
  }
</style>

<script>
  function initNavbarBehavior() {
    const header = document.getElementById('header');
    const hamburger = document.getElementById('hamburger');
    const navLinks = document.getElementById('nav-links');
    const links = document.querySelectorAll('.nav-link');
    const sections = document.querySelectorAll('section[id]');

    // 1. Scroll effect on Header
    function handleScroll() {
      if (window.scrollY >= 50) {
        header?.classList.add('scrolled');
      } else {
        header?.classList.remove('scrolled');
      }
    }
    window.addEventListener('scroll', handleScroll);
    handleScroll();

    // 2. Mobile Menu toggle with Backdrop
    const backdrop = document.getElementById('menu-backdrop');
    if (hamburger && navLinks && backdrop) {
      // Remove previous listener to avoid double triggers on hot-reloading
      const newHamburger = hamburger.cloneNode(true);
      hamburger.parentNode?.replaceChild(newHamburger, hamburger);

      function openMenu() {
        newHamburger.classList.add('active');
        navLinks.classList.add('active');
        backdrop?.classList.add('active');
        document.body.classList.add('menu-open'); // prevent scrolling when menu is open
      }

      function closeMenu() {
        newHamburger.classList.remove('active');
        navLinks.classList.remove('active');
        backdrop?.classList.remove('active');
        document.body.classList.remove('menu-open'); // restore scrolling
      }

      newHamburger.addEventListener('click', () => {
        if (navLinks.classList.contains('active')) {
          closeMenu();
        } else {
          openMenu();
        }
      });

      // Close menu when clicking on a link
      links.forEach(link => {
        link.addEventListener('click', closeMenu);
      });

      // Close menu when clicking on the backdrop
      backdrop.addEventListener('click', closeMenu);
    }

    // 3. Scroll Active Link Highlight
    function highlightActiveLink() {
      const scrollY = window.pageYOffset;

      sections.forEach((current: any) => {
        const sectionHeight = current.offsetHeight;
        const sectionTop = current.offsetTop - 80;
        const sectionId = current.getAttribute('id');

        if (scrollY > sectionTop && scrollY <= sectionTop + sectionHeight) {
          document.querySelector(`.nav-link[href*=${sectionId}]`)?.classList.add('active-link');
        } else {
          document.querySelector(`.nav-link[href*=${sectionId}]`)?.classList.remove('active-link');
        }
      });
    }
    window.addEventListener('scroll', highlightActiveLink);
    highlightActiveLink();
  }

  // Init behavior on first page load
  initNavbarBehavior();

  // Re-run on View Transitions navigation
  document.addEventListener('astro:page-load', initNavbarBehavior);
</script>
