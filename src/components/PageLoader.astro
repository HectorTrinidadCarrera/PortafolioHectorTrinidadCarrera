---
import Skeleton from './Skeleton.astro';
---

<div id="global-page-loader" class="fixed inset-0 z-[99999] bg-[#080808] flex flex-col px-6 md:px-12 pt-8 transition-opacity duration-700 ease-in-out">
  <div class="container mx-auto flex flex-col h-full">
    
    <!-- Falso Header (Skeleton) -->
    <div class="flex justify-between items-center w-full mb-24">
      <Skeleton class="h-8 w-12 md:w-32 rounded-xl" />
      <div class="hidden md:flex gap-8">
        <Skeleton class="h-5 w-20 rounded-full" />
        <Skeleton class="h-5 w-20 rounded-full" />
        <Skeleton class="h-5 w-20 rounded-full" />
        <Skeleton class="h-5 w-20 rounded-full" />
      </div>
      <div class="flex gap-4">
        <Skeleton class="h-10 w-10 rounded-full" />
        <Skeleton class="h-10 w-24 rounded-full" />
      </div>
    </div>
    
    <!-- Falso Hero (Skeleton) -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center flex-1 pb-20">
      
      <!-- Lado izquierdo (Textos) -->
      <div class="lg:col-span-7 flex flex-col gap-6">
        <Skeleton class="h-6 w-32 rounded-full" />
        <div class="space-y-4">
          <Skeleton class="h-16 w-full max-w-xl rounded-2xl" />
          <Skeleton class="h-16 w-4/5 max-w-lg rounded-2xl" />
        </div>
        <Skeleton class="h-8 w-64 mt-4 rounded-full" />
        <div class="space-y-3 mt-4">
          <Skeleton class="h-4 w-full max-w-md rounded-full" />
          <Skeleton class="h-4 w-5/6 max-w-md rounded-full" />
        </div>
        
        <!-- Botones y redes -->
        <div class="flex gap-4 mt-8 flex-wrap">
          <Skeleton class="h-12 w-40 rounded-full" />
          <Skeleton class="h-12 w-40 rounded-full" />
          <Skeleton class="h-12 w-40 rounded-full" />
        </div>
        <div class="flex gap-6 mt-8">
          <Skeleton class="h-12 w-12 rounded-full" />
          <Skeleton class="h-12 w-12 rounded-full" />
          <Skeleton class="h-12 w-12 rounded-full" />
        </div>
      </div>
      
      <!-- Lado derecho (Avatar) -->
      <div class="lg:col-span-5 flex justify-center">
        <Skeleton class="h-64 w-64 sm:h-80 sm:w-80 rounded-full bg-primary/20" />
      </div>
    </div>
    
  </div>
</div>

<script>
  function initLoader() {
    const loader = document.getElementById("global-page-loader");
    if (!loader) return;
    
    // Revisar si ya cargó antes en esta sesión para no molestarlo siempre
    const hasVisited = sessionStorage.getItem("portfolio_loaded_v1");
    
    if (hasVisited) {
      // Si ya lo vio, lo ocultamos de inmediato sin animación
      loader.style.display = "none";
      return;
    }
    
    // Si es la primera vez, marcamos que ya lo vio y hacemos la animación
    sessionStorage.setItem("portfolio_loaded_v1", "true");
    
    // Tiempo de carga falso de 1.2 segundos para mostrar el skeleton
    setTimeout(() => {
      loader.classList.add("opacity-0");
      loader.classList.add("pointer-events-none"); // evitar clics mientras se desvanece
      
      // Eliminar del DOM después de que termine la transición de opacidad (700ms)
      setTimeout(() => {
        loader.style.display = "none";
      }, 700);
    }, 1200);
  }

  // Ejecutar el loader
  // Usamos DOMContentLoaded para la primera carga, pero en Astro a veces se ejecuta antes el script en linea
  initLoader();
</script>
